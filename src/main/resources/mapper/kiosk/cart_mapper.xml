<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.board_cafe_kiosk_2603.mapper.kiosk.CartMapper">

    <!-- tableNumber(표시 번호) → cafe_table.id(PK) 변환 -->
    <select id="findCafeTableIdByTableNumber" resultType="org.example.board_cafe_kiosk_2603.domain.kiosk.Cart">
        SELECT id
        FROM cafe_table
        WHERE table_number = #{tableNumber}
        LIMIT 1
    </select>

    <select id="findByTableId" resultType="org.example.board_cafe_kiosk_2603.domain.kiosk.Cart">
        SELECT id, table_id, updated_at
        FROM cart
        WHERE table_id = #{tableId}
    </select>

    <insert id="insert">
        INSERT INTO cart (table_id)
        VALUES (#{tableId})
    </insert>

    <delete id="deleteByTableId">
        DELETE FROM cart
        WHERE table_id = #{tableId}
    </delete>

    <update id="updateTimestamp">
        UPDATE cart
        SET updated_at = CURRENT_TIMESTAMP
        WHERE id = #{cartId}
    </update>

</mapper>
