<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.board_cafe_kiosk_2603.mapper.kiosk.CafePackageMapper">

    <resultMap id="CafePackageResultMap" type="org.example.board_cafe_kiosk_2603.domain.kiosk.CafePackage">
        <id     property="id"               column="id"/>
        <result property="name"             column="name"/>
        <result property="type"             column="type"/>
        <result property="durationMinutes"  column="duration_minutes"/>
        <result property="basePrice"        column="base_price"/>
        <result property="extraPricePerMin" column="extra_price_per_min"/>
        <result property="active"           column="is_active"/>
        <result property="updatedAt"        column="updated_at"/>
    </resultMap>

    <select id="findAllActive" resultMap="CafePackageResultMap">
        SELECT id, name, type, duration_minutes, base_price,
               extra_price_per_min, is_active, updated_at
        FROM cafe_package
        WHERE is_active = TRUE
        ORDER BY base_price ASC
    </select>

    <select id="findById" parameterType="int" resultMap="CafePackageResultMap">
        SELECT id, name, type, duration_minutes, base_price,
               extra_price_per_min, is_active, updated_at
        FROM cafe_package
        WHERE id = #{id}
    </select>

</mapper>
