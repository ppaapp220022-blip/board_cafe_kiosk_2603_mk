<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.board_cafe_kiosk_2603.mapper.admin.PointMapper">

    <!-- 포인트 계좌 생성 -->
    <insert id="insertPoint" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board_cafe_kiosk_2603.point (phone, balance)
        VALUES (#{phone}, 0)
    </insert>

    <!-- 전화번호로 포인트 계좌 조회 -->
    <select id="selectByPhone" resultType="org.example.board_cafe_kiosk_2603.domain.admin.Point">
        SELECT id, phone, balance, updated_at
        FROM board_cafe_kiosk_2603.point
        WHERE phone = #{phone}
    </select>

    <!-- 포인트 잔액 업데이트 -->
    <update id="updateBalance">
        UPDATE board_cafe_kiosk_2603.point
        SET balance = #{balance}
        WHERE id = #{id}
    </update>

</mapper>