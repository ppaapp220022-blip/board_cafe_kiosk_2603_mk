<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.board_cafe_kiosk_2603.repository.admin.product.CategoryMapper">

    <!-- 카테고리 전체 목록 조회 -->
    <select id="findAll" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.Category">
        SELECT id, name, type
        FROM category
        ORDER BY type, id
    </select>

    <!-- type 기준 카테고리 목록 조회 -->
    <select id="findByType" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.Category">
        SELECT id, name, type
        FROM category
        WHERE type = #{type}
        ORDER BY id
    </select>

    <!-- PK로 카테고리 단건 조회 -->
    <select id="findById" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.Category">
        SELECT id, name, type
        FROM category
        WHERE id = #{id}
    </select>

    <!-- 카테고리 등록 -->
    <insert id="insert">
        INSERT INTO category (name, type)
        VALUES (#{name}, #{type})
    </insert>

    <!-- 카테고리 수정 -->
    <update id="update">
        UPDATE category
        SET name = #{name},
            type = #{type}
        WHERE id = #{id}
    </update>

    <!-- 카테고리 삭제 -->
    <delete id="delete">
        DELETE FROM category
        WHERE id = #{id}
    </delete>

</mapper>