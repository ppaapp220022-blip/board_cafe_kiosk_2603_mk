<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.board_cafe_kiosk_2603.mapper.admin.product.GameItemMapper">

    <sql id="selectGameItemWithGame">
        SELECT gi.id,
               gi.game_id,
               g.name AS game_name,
               gi.serial_number,
               gi.status
        FROM game_item gi
                 INNER JOIN game g ON gi.game_id = g.id
    </sql>

    <!-- 전체 게임 아이템 목록 조회 -->
    <select id="findAll" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.GameItem">
        <include refid="selectGameItemWithGame"/>
        ORDER BY gi.game_id, gi.id
    </select>

    <!-- game_id 기준 게임 아이템 목록 조회 -->
    <select id="findByGameId" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.GameItem">
        <include refid="selectGameItemWithGame"/>
        WHERE gi.game_id = #{gameId}
        ORDER BY gi.id
    </select>

    <!-- status 기준 게임 아이템 목록 조회 -->
    <select id="findByStatus" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.GameItem">
        <include refid="selectGameItemWithGame"/>
        WHERE gi.status = #{status}
        ORDER BY gi.game_id, gi.id
    </select>

    <!-- PK로 게임 아이템 단건 조회 -->
    <select id="findById" resultType="org.example.board_cafe_kiosk_2603.domain.admin.product.GameItem">
        <include refid="selectGameItemWithGame"/>
        WHERE gi.id = #{id}
    </select>

    <!-- 게임 아이템 등록 -->
    <insert id="insert">
        INSERT INTO game_item (game_id, serial_number, status)
        VALUES (#{gameId}, #{serialNumber}, #{status})
    </insert>

    <!-- 게임 아이템 수정 -->
    <update id="update">
        UPDATE game_item
        SET game_id       = #{gameId},
            serial_number = #{serialNumber},
            status        = #{status}
        WHERE id = #{id}
    </update>

    <!-- 게임 아이템 삭제 -->
    <delete id="delete">
        DELETE FROM game_item
        WHERE id = #{id}
    </delete>

    <!-- 게임 아이템 상태만 변경 -->
    <update id="updateStatus">
        UPDATE game_item
        SET status = #{status}
        WHERE id = #{id}
    </update>

</mapper>