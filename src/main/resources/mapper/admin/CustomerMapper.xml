<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.board_cafe_kiosk_2603.mapper.admin.CustomerMapper">

    <!-- 신규 고객 등록 -->
    <insert id="insertCustomer" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board_cafe_kiosk_2603.customer (phone)
        VALUES (#{phone})
    </insert>

    <!-- 전화번호로 고객 조회 -->
    <select id="selectByPhone" resultType="org.example.board_cafe_kiosk_2603.domain.admin.Customer">
        SELECT id, phone, is_active, created_at
        FROM board_cafe_kiosk_2603.customer
        WHERE phone = #{phone}
    </select>
</mapper>